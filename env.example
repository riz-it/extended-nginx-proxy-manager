# Database Configuration (Multi-Database Support)
DB_TYPE=sqlite      # Options: sqlite, mysql, postgresql (default)

# PostgreSQL / MySQL Configuration 
DB_HOST=127.0.0.1
DB_PORT=5432        # or 3306 for MySQL
DB_USER=root
DB_PASSWORD=secret
DB_NAME=npm

# Application Configuration
TZ=Asia/Jakarta
PORT=3001
NODE_ENV=production

# The DATABASE_URL is generated automatically by startScript.sh
