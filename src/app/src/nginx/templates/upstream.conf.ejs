upstream <%= name %> {
    <% if (enableLoadBalancing) { %>
      <% if (algorithm === 'least_conn') { %>least_conn;<% } else if (algorithm === 'ip_hash') { %>ip_hash;<% } %>
    <% } %>
    <% let primaryAssigned = false; %>
    <% upstreams.forEach(function(u, index) { %>
    <% 
      let isBackup = u.isBackup;
      if (!enableLoadBalancing) {
          if (!primaryAssigned && !u.isBackup) {
             primaryAssigned = true;
          } else {
             isBackup = true;
          }
      }
    %>
    <% if (u.protocol === 'https') { %>
    # Internal Bridge for <%= u.host %>
    server 127.0.0.1:<%= 10000 + u.id %> weight=<%= u.weight || 1 %> max_fails=<%= u.maxFails || 3 %> fail_timeout=<%= u.failTimeout || '10s' %><% if (isBackup) { %> backup<% } %>;
    <% } else { %>
    server <%= u.host %> weight=<%= u.weight || 1 %> max_fails=<%= u.maxFails || 3 %> fail_timeout=<%= u.failTimeout || '10s' %><% if (isBackup) { %> backup<% } %>;
    <% } %>
    <% }); %>

    # No keepalive to ensure fresh connections identical to NPM native behavior
}

server {
    listen <%= listenPort || 80 %>;

    # ── Traffic Aggregation (UDP Syslog to NestJS) ──
    set $lb_id "<%= id %>";
    access_log syslog:server=127.0.0.1:44444,tag=lb_traffic traffic_json_fmt;

    # ── Default Proxy Settings (inheritable by all locations) ─────
    proxy_connect_timeout 3s;
    proxy_read_timeout 10s;
    proxy_send_timeout 10s;
    proxy_buffering on;
    proxy_buffer_size 4k;
    proxy_buffers 8 4k;

<% if (typeof customNginxConfig === 'string' && customNginxConfig.trim()) { %>
    # ── Custom Nginx Configuration ───────────────────────────────
<%= customNginxConfig.split('\n').map(line => '    ' + line).join('\n') %>
<% } %>

    location / {
        # We always use http:// to the upstream block, because HTTPS upstreams 
        # are proxied through our internal HTTP-to-HTTPS bridges below.
        proxy_pass http://<%= name %>;

        <% if (enableFailover) { %>
        # ── Failover & Retry Logic ──────────────────────────────
        proxy_next_upstream error timeout http_500 http_502 http_503 http_504;
        proxy_next_upstream_tries 3;
        proxy_next_upstream_timeout 5s;
        <% } else { %>
        # ── Failover Disabled ───────────────────────────────────
        proxy_next_upstream off;
        <% } %>

        # ── HTTP/1.1 Keepalive & Websockets ─────────────────────
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $http_connection;

        # -- Header Forwarding -----------------------------------------------
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $http_x_real_ip;
        proxy_set_header X-Forwarded-For $http_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header X-Forwarded-Scheme $http_x_forwarded_scheme;
    }
}

<% /* ── Internal Bridges for HTTPS Upstreams ─────────────────────────── */ %>
<% upstreams.forEach(function(u) { %>
<% if (u.protocol === 'https') { %>
server {
    listen 127.0.0.1:<%= 10000 + u.id %>;
    
    location / {
        proxy_pass https://<%= u.host %>;
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        
        # Pass headers through the bridge
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header X-Forwarded-Scheme $http_x_forwarded_scheme;
    }
}
<% } %>
<% }); %>