// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LoadBalancer {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  listenPort Int       @default(80) @map("listen_port")
  status    String     @default("active") // active | inactive | error
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  upstreams Upstream[]

  @@map("load_balancers")
}

model Upstream {
  id             Int          @id @default(autoincrement())
  host           String       // e.g. "10.0.0.1:3000"
  weight         Int          @default(1)
  maxFails       Int          @default(3) @map("max_fails")
  failTimeout    String       @default("10s") @map("fail_timeout")
  isBackup       Boolean      @default(false) @map("is_backup")
  protocol       String       @default("http")
  isActive       Boolean      @default(true) @map("is_active")
  
  loadBalancer   LoadBalancer  @relation(fields: [loadBalancerId], references: [id], onDelete: Cascade)
  loadBalancerId Int           @map("load_balancer_id")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("upstreams")
}
